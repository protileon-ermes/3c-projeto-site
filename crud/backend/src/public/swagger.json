{
  "openapi": "3.1.0",
  "info": {
    "title": "CRUD API",
    "version": "1.0.0",
    "description": "Documentação da API para o projeto CRUD usando OpenAPI 3.1.0."
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Servidor local"
    }
  ],
  "paths": {
    "/api/resource": {
      "get": {
        "summary": "Obter todos os recursos",
        "responses": {
          "200": {
            "description": "Lista de recursos",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "id": {
                        "type": "integer"
                      },
                      "name": {
                        "type": "string"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}